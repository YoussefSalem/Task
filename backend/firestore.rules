rules_version = '2';

// Baseline security rules. Role gates + the security-critical sealed-bid
// blinding (PRD §3.2). Field-level validation is tightened per feature phase.
// NOTE: App Check enforcement is configured at the API level (PRD §1.1), not in
// these rules — rules cannot inspect the App Check token directly.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && role() == 'admin';
    }

    // --- users (customers + technicians + admins) ---
    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId);
      allow update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();

      // In-app notification feed. There is no Cloud Function fan-out yet, so any
      // signed-in user may drop a notification into another user's feed (the
      // acting client writes it). Only the owner reads or mutates their feed.
      // Tightening create to server-only happens when fan-out moves to Functions.
      match /notifications/{notificationId} {
        allow read: if isSelf(userId);
        allow create: if isSignedIn();
        allow update, delete: if isSelf(userId);
      }
    }

    // --- addresses ---
    match /addresses/{addressId} {
      allow read, delete: if (resource != null && isSelf(resource.data.user_id)) || isAdmin();
      allow create: if isSelf(request.resource.data.user_id);
      allow update: if (resource != null && isSelf(resource.data.user_id)) || isAdmin();
    }

    // --- jobs (source of truth) ---
    match /jobs/{jobId} {
      // Reads refined per phase (job owner / assigned technician / admin).
      allow read: if isSignedIn();
      allow create: if isSelf(request.resource.data.customer_id);
      // Job owner can update their own job (accept, counter, cancel, etc).
      // Technician can only advance stage. Admin unrestricted.
      allow update: if isAdmin()
        || isSelf(resource.data.customer_id)
        || (isSignedIn() && role() == 'technician' &&
            request.resource.data.status in ['enRoute', 'inProgress', 'completed']);
      allow delete: if isAdmin();

      // Sealed bids: a technician writes only their own quote (doc id == uid)
      // and reads only their own; the job's customer and admins read all.
      match /quotes/{technicianId} {
        allow create: if isSelf(technicianId) && role() == 'technician';
        allow read: if isSelf(technicianId)
          || isAdmin()
          || get(/databases/$(database)/documents/jobs/$(jobId)).data.customer_id == request.auth.uid;
        allow update, delete: if isAdmin();
      }

      // Live location trail — only the technician writes; participants read.
      match /tracking/{pointId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && role() == 'technician';
      }

      // Per-(job, technician) chat threads. A customer holds a separate
      // conversation with each technician bidding on the job; the technician who
      // owns the thread is the document id. (30-day TTL cleanup handled by a
      // scheduled function.)
      match /threads/{technicianId} {
        // For read/update/delete: check fields stored in the thread doc itself so
        // collection-group queries work (a get() on jobId would fail because the
        // wildcard is unresolved at collection-group evaluation time).
        function isThreadParticipant() {
          return isSignedIn() && (
            resource.data.customer_id == request.auth.uid
            || resource.data.technician_id == request.auth.uid
            || isAdmin()
          );
        }

        // For creates: the doc doesn't exist yet, so use request.resource.data.
        function canCreateThread() {
          return isSignedIn() && (
            request.resource.data.customer_id == request.auth.uid
            || request.resource.data.technician_id == request.auth.uid
            || isAdmin()
          );
        }

        allow read, update, delete: if isThreadParticipant();
        allow create: if canCreateThread();

        match /messages/{messageId} {
          // Messages live under a known (jobId, technicianId) path so a get()
          // on the parent job document is safe here (no wildcard ambiguity).
          allow read, create: if isSignedIn() && (
            request.auth.uid == technicianId
            || get(/databases/$(database)/documents/jobs/$(jobId)).data.customer_id == request.auth.uid
            || isAdmin()
          );
          allow update, delete: if isAdmin();
        }
      }

      // Post-job reviews. Only the reviewer creates; everyone reads.
      match /reviews/{reviewerId} {
        allow create: if isSelf(reviewerId);
        allow read: if isSignedIn();
        allow update, delete: if isAdmin();
      }
    }
  }
}
